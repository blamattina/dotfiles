Brewfile.lock.json
.DS_Store

# Symlink pointing at an external "local" overlay repo (e.g. dotfiles-local on GH Enterprise).
# The setup script auto-stows ./local if this exists.
/local

# Fisher-installed plugin files — managed via fish_plugins, not committed
common/dot-config/fish/functions/*
common/dot-config/fish/conf.d/*
common/dot-config/fish/completions/

# Keep our own fish files
!common/dot-config/fish/functions/g.fish
!common/dot-config/fish/functions/git-safety-dance.fish
!common/dot-config/fish/functions/git-list-merged-branches.fish
!common/dot-config/fish/functions/git-delete-merged-branches.fish
!common/dot-config/fish/functions/fzf-checkout.fish
!common/dot-config/fish/functions/pipe-git-command-to-diff-so-fancy.fish
!common/dot-config/fish/conf.d/aliases.fish
